  "faq": [
    {
      "question": "What is the check-in and check-out time?",
      "answer": "Standard check-in is 3 PM and check-out is 12 PM. Early check-in and late checkout available subject to room availability. Concierge can arrange with 24-hour notice."
    },

    {
      "question": "Do you offer room upgrades?",
      "answer": "Yes! Room upgrades are available based on occupancy. Executive Suite and Penthouse guests receive complimentary upgrades if available. Concierge can facilitate upgrades for all guests."
    },

    {
      "question": "What is the parking situation?",
      "answer": "Complimentary valet parking for all hotel guests. Self-parking also available. Underground parking facility with EV charging stations."
    },

    {
      "question": "Is WiFi included?",
      "answer": "Yes, complimentary high-speed WiFi (WiFi 6) is included for all guests. Presidential and Penthouse suites include dedicated fiber optic connections."
    },

    {
